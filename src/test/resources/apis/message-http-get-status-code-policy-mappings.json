{
    "id": "status-code-policy-test-api",
    "name": "Status Code Policy Test API",
    "gravitee": "4.0.0",
    "type": "message",
    "listeners": [
        {
            "type": "http",
            "paths": [
                {
                    "path": "/status-code-policy"
                }
            ],
            "entrypoints": [
                {
                    "type": "http-get",
                    "configuration": {
                        "messagesLimitCount":  12,
                        "messagesLimitDurationMs": 500
                    }
                }
            ]
        }
    ],
    "endpointGroups": [
        {
            "name": "default",
            "type": "mock",
            "endpoints": [
                {
                    "name": "default-endpoint",
                    "type": "mock",
                    "weight": 1,
                    "inheritConfiguration": false,
                    "configuration": {
                        "messageInterval": 1,
                        "messageContent": "message",
                        "messageCount": 1000
                    }
                }
            ]
        }
    ],
    "flows": [
        {
            "name": "flow-1",
            "enabled": true,
            "selectors": [
                {
                    "type": "http",
                    "path": "/",
                    "pathOperator": "START_WITH",
                    "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
                }
            ],
            "request": [],
            "response": [
                {
                    "name": "Status Code Transformation Policy",
                    "policy": "status-code",
                    "enabled": true,
                    "configuration": {
                        "statusMappings": [
                            {
                                "inputStatusCode": 200,
                                "outputStatusCode": 201
                            },
                            {
                                "inputStatusCode": 419,
                                "outputStatusCode": 401
                            },
                            {
                                "inputStatusCode": 404,
                                "outputStatusCode": 200
                            },
                            {
                                "inputStatusCode": 515,
                                "outputStatusCode": 505
                            }
                        ]
                    }
                }
            ]
        }
    ],
    "analytics": {
        "enabled": false
    },
    "resources": []
}
